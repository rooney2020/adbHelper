{
  "name": "adb-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:build\" \"npm:dev:electron:run\"",
    "dev:renderer": "vite",
    "dev:electron:build": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on tcp:5173 dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "package:linux": "npm run build && electron-packager . adb-helper --platform=linux --arch=x64 --out=release --overwrite --prune=true --ignore=release --ignore=node_modules/electron-packager",
    "package:win": "npm run build && electron-packager . adb-helper --platform=win32 --arch=x64 --out=release --overwrite --prune=true --ignore=release --ignore=node_modules/electron-packager",
    "package:all": "npm run package:linux && npm run package:win",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "iconv-lite": "^0.6.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.1",
    "cross-env": "^10.0.0",
    "electron": "^35.0.0",
    "electron-packager": "^17.1.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.0"
  }
}
